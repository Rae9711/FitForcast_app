# FitForecast Backend Configuration
# Copy this file to .env and fill in your actual values

# Database
DATABASE_URL="postgresql://fitforecast:fitforecast@localhost:5432/fitforecast?schema=public"

# Server
PORT=3000
NODE_ENV=development

# Auth (for future use)
# JWT_SECRET=your-secret-key-here

# Logging
LOG_LEVEL=info

# CORS
# CORS_ORIGIN=http://localhost:5173

# Default User ID (for MVP development without auth)
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
